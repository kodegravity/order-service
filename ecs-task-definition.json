{
  "family": "order-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::512383926725:role/food-delivery-dev-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::512383926725:role/food-delivery-dev-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "order-service",
      "image": "512383926725.dkr.ecr.us-east-2.amazonaws.com/order-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8083,
          "hostPort": 8083,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_SCHEMA", "value": "order_service" }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:512383926725:secret:food-delivery/dev/db/credentials-LnJxkJ:host::"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:512383926725:secret:food-delivery/dev/db/credentials-LnJxkJ:port::"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:512383926725:secret:food-delivery/dev/db/credentials-LnJxkJ:dbname::"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:512383926725:secret:food-delivery/dev/db/credentials-LnJxkJ:username::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:512383926725:secret:food-delivery/dev/db/credentials-LnJxkJ:password::"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8083/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/order-service",
          "awslogs-region":        "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "stopTimeout": 30
    }
  ]
}
